FROM iiidev/iii:0.11.2 AS iii

FROM node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=iii /app/iii /usr/local/bin/iii

RUN npm install -g @agentmemory/agentmemory@0.9.21 \
    && cp /usr/local/lib/node_modules/@agentmemory/agentmemory/dist/iii-config.docker.yaml \
        /usr/local/lib/node_modules/@agentmemory/agentmemory/dist/iii-config.yaml

ENV AGENTMEMORY_HOST=0.0.0.0
ENV AGENTMEMORY_PORT=3111

VOLUME ["/root/.agentmemory"]

CMD ["sh", "-lc", "rm -f /root/.agentmemory/iii.pid /root/.agentmemory/engine-state.json && exec agentmemory"]
